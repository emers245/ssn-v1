{
    "manifest": {
        "$BASE_DIR": ".",
        "$INPUTS_DIR": "$BASE_DIR/inputs",
        "$NETWORK_DIR": "$BASE_DIR/network",
        "$COMPONENTS_DIR": "$BASE_DIR/components"
    },
    "target_simulator": "SSN",
    "run": {
        "tstop": 3000.0,
        "dt": 0.1,
        "r_init": {"type": "uniform", "E": 0.0, "I": 0.0},
        "gaussian_noise": 0,
        "method": "RK45"
    },
    "inputs": {
        "sampling_rate": 20.0
    },
    "outputs": {
        "log_file": "log.txt",
        "outputs_dir": "$BASE_DIR/outputs"
    },
    "components": {
        "SSN_cells": "$COMPONENTS_DIR/SSN_cells",
        "E": "config.E.json",
        "I": "config.I.json"
    },
    "network": {
        "network_config": "$NETWORK_DIR/config.network.EI512_tutorial.json",
        "rand_seed": 42,
        "map_seed": 42
    }
}
